[mysqld]
# ── Authentication ────────────────────────────────────────────
default-authentication-plugin       = mysql_native_password
sha256-password-auto-generate-rsa-keys = OFF

# ── Timezone ─────────────────────────────────────────────────
default-time-zone                   = +05:30

# ── SQL Mode (ONLY_FULL_GROUP_BY removed to fix GROUP BY) ─────
sql-mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# ── Binary log ───────────────────────────────────────────────
# This is a local mirror — binary logging is not needed and causes
# massive storage growth (gigabytes per sync cycle).
skip-log-bin
log-bin-trust-function-creators     = 1

# ── InnoDB tuning (reclaim undo log space) ────────────────────
innodb_undo_log_truncate            = ON
innodb_max_undo_log_size            = 256M

# ── GROUP_CONCAT max length ───────────────────────────────────
group-concat-max-len                = 4294967295

# ── Query timeout (ms) ────────────────────────────────────────
max-execution-time                  = 60000
