# ─────────────────────────────────────────────
#  Production / Remote MySQL Server (direct)
# ─────────────────────────────────────────────
PROD_DB_HOST=10.10.0.1
PROD_DB_PORT=3306
PROD_DB_USER=your_db_user
# Wrap in double quotes if password contains special chars: & $ ' [ ] ! %
# Escape $ with \$  (e.g. PROD_DB_PASS="my\$ecret&pass")
PROD_DB_PASS=your_production_password

# ─────────────────────────────────────────────
#  Local MySQL (Docker)
# ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=local_root_password
MYSQL_LOCAL_PORT=3306

# ─────────────────────────────────────────────
#  MySQL Users – JSON array (created locally)
#  { "user":"", "password":"", "host":"", "privileges":"" }
# ─────────────────────────────────────────────
MYSQL_USERS_JSON='[
  {"user":"app_user",  "password":"AppP@ssw0rd!",  "host":"%",        "privileges":"ALL PRIVILEGES"},
  {"user":"readonly",  "password":"R3adOnly#2024",  "host":"localhost", "privileges":"SELECT"}
]'

# ─────────────────────────────────────────────
#  Sync Schedule
#  SYNC_INTERVAL_HOURS : 2 or 3
#  SYNC_CRON_OVERRIDE  : custom cron expression (overrides interval)
# ─────────────────────────────────────────────
SYNC_INTERVAL_HOURS=2
SYNC_CRON_OVERRIDE=

# ─────────────────────────────────────────────
#  Paths
# ─────────────────────────────────────────────
BACKUP_DIR=/tmp/erp_backups
LOG_DIR=/var/log/erp_sync

# ─────────────────────────────────────────────
#  Backup Retention
#  BACKUP_KEEP_DAYS  : delete dumps older than N days
#  BACKUP_KEEP_COUNT : always keep at least N most recent dumps
#  LOG_KEEP_COUNT    : keep N most recent sync log files
# ─────────────────────────────────────────────
BACKUP_KEEP_DAYS=1
BACKUP_KEEP_COUNT=3
LOG_KEEP_COUNT=14

# ─────────────────────────────────────────────
#  Web Dashboard (api.py)
#  API_TOKEN : secret token required to log in
#              — change this to something strong!
#  API_PORT  : port the dashboard listens on
# ─────────────────────────────────────────────
API_TOKEN=change_me_strong_token
API_PORT=8080
