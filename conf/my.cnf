[mysqld]
# Force all clients (including SQLyog) to use mysql_native_password
# Disables caching_sha2_password and sha256_password (Error 2058 fix)
default_authentication_plugin       = mysql_native_password
sha256_password_auto_generate_rsa_keys      = OFF
caching_sha2_password_auto_generate_rsa_keys = OFF

# Performance tuning for local dev sync
innodb_buffer_pool_size = 512M
max_allowed_packet      = 256M
